# Get your API key at https://moondev.com
MOONDEV_API_KEY=your_api_key_here

# Grover Market Terminal optional connectors
# RSS news works without keys. NewsAPI adds broader article search.
NEWSAPI_API_KEY=

# Optional CoinGecko demo/pro key for /api/v3/global. Leave blank for public/no-key attempts.
COINGECKO_API_KEY=

# Refresh cadence in seconds
GROVER_REFRESH_SEC=30
GROVER_NEWS_SEC=90

# Optional custom terminal commands. Either JSON list or commands split by ||
# GROVER_TERMINAL_COMMANDS=["python examples/01_liquidations.py", "python examples/19_market_data.py"]

# For AI Swarm Agent (optional - see ai_agents/ folder)
# OpenRouter - Get key at https://openrouter.ai (one key for ALL models!)
OPENROUTER_API_KEY=your_openrouter_key_here
